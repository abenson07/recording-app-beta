# Copy to .env.local and fill in from the Supabase dashboard:
# Project Settings → API → Project URL and anon (public) key.
#
# For local CLI: run `npm run db:start`, then `npx supabase status` for API URL and anon key.
#
# If the dashboard only shows a publishable key, you can use:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY= (same role as anon for the JS client)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
